<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="ATM"
         connectionString="Server=.;Database=ATM;Trusted_Connection=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="UzsToUsdRate" value="12000" />
    <add key="SessionTimeoutSeconds" value="30" />
    <add key="BootstrapDatabaseOnStartup" value="true" />
    <add key="SeedDefaultAdminOnStartup" value="false" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>
